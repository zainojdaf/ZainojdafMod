# Force C++ detection in the assets folder
gdbrowser/assets/*.cpp linguist-language=C++
gdbrowser/assets/*.hpp linguist-language=C++
gdbrowser/assets/*.h linguist-language=C++
gdbrowser/assets/*.cc linguist-language=C++

# CRITICAL: Mark them as detectable so they count towards stats
gdbrowser/assets/*.cpp linguist-detectable=true
gdbrowser/assets/*.hpp linguist-detectable=true
gdbrowser/assets/*.h linguist-detectable=true
gdbrowser/assets/*.cc linguist-detectable=true   
